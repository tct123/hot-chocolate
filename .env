# Google Maps SDK for Android — restricted to package com.brents.hotchocolate + debug/release SHA-1s.
# Get the key from https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY_ANDROID=

# Google Maps JavaScript API for the web build — inlined into the public JS bundle (EXPO_PUBLIC_*).
# The string is readable by anyone who loads the site; security comes from GCP restrictions, not secrecy:
#   - Application restriction: HTTP referrers → http://localhost:8081/*, plus your prod domain.
#   - API restriction: Maps JavaScript API only.
# Get the key from https://console.cloud.google.com/google/maps-apis/credentials
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY_WEB=
