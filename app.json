{
  "expo": {
    "name": "Hot Chocolate App",
    "slug": "hot-chocolate",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hot-chocolate",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "de.cmg.hot-chocolate",
      "icon": "./assets/app.icon",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "android": {
            "image": "./assets/images/icon.png",
            "imageWidth": 76
          },
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "This app uses your location to show nearby hot chocolate spots on the map."
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-image",
      "expo-sqlite",
      "expo-asset",
      "@bacons/apple-colors",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8824ae9f-01b9-4bc7-b448-6c8499dbeb8d"
      }
    },
    "android": {
      "package": "com.brents.hotchocolate"
    }
  }
}
